# Base de données (Postgres en prod, SQLite possible en dev en changeant le provider dans prisma/schema.prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/hublink"

# Authentification
JWT_SECRET="change-moi-en-production"

# Notifications push (générées avec: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
